		(uuid "c2284352-4549-49fb-be6f-3007c1e40167")
	)
	(text_box "This load switch includes: \n\nOutput Discharge (30mA)\nOver Current Protection (4A)\nOutput Short Protection (8A)\nThermal Shutdown (145°C)\nOvervoltage Protection (19.1V)\n\nR_{DS} = 50mΩ typ. at V_{IN} = 12V"
		(exclude_from_sim no)
		(at 374.65 109.22 0)
		(size 33.02 22.35)
