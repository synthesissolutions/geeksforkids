	(text "Following  reccomended values for components:\nC_IN = 2x10uF + 1x0.1uF\nC_OUT = 2x47uF (derates as VOUT increases)\nC_FF = 33pF\nR_FF = 1kΩ\nC_BOOT = 0.1uF"
		(exclude_from_sim no)
		(at 27.94 135.636 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "85242740-8e32-4b1f-a33c-8d234e850bef")
	)
	(text "Leaving RT open defaults f_SW = 500kHz.\nSince UVLO is not required, EN pin is tied to VIN. \n\nTI also reccomends a 47uF or 100uF electrolytic \ncap on VIN to prevent false UVLO triggering. "
		(exclude_from_sim no)
		(at 27.94 149.352 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "b23eb585-6711-47b1-9d45-c88a5ac42c3a")
	)
	(text "DESIGN NOTES"
		(exclude_from_sim no)
		(at 25.4 99.06 0)
		(effects
