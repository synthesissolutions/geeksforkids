			)
			(justify left bottom)
		)
		(uuid "ccfe856a-96b2-4b86-9280-fcdb86afba82")
	)
	(text "VIN_MAX = 36V\nI_OUT = 5A\nf_SW = 500kHz\nAsume K_IND = 0.4\n\nFor VOUT = 3.3V, L_MIN = 3uH. Choose L = 3.3uH. \nFor VOUT = 5.0V, L_MIN = 4.3uH. Choose L = 4.7uH\nFor VOUT = 12.0V, L_MIN = 8uH Choose L = 10uH.\n"
		(exclude_from_sim no)
		(at 28.194 119.888 0)
		(effects
