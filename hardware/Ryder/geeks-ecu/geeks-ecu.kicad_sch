			)
		)
		(uuid "2ee27d06-84c0-4f9f-aada-c4408ae75ac1")
	)
	(text_box "J103 connects to a switch with intgrated LED. R330 is used to drop approximately 12V to stay within SW ratings."
		(exclude_from_sim no)
